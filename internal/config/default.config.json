{
    "metrics": {
        "port": "9090"
    },
    "connections": {
        "tcp": [
            {
                "type": "tcp",
                "port": "9095",
                "lbstrategy": "round-robin",
                "transport": {
                    "dialTimeout": "5s",
                    "keepAlive": "30s"
                },
                "hosts": [
                    { "host": "localhost", "port": "9096" },
                    { "host": "localhost", "port": "9097" }
                ]
            }
        ],
        "http": [
            {
                "type": "http",
                "prefix": "/api",
                "lbstrategy": "least-connections",
                "transport": {
                    "dialTimeout": "5s",
                    "responseHeaderTimeout": "30s",
                    "idleConnTimeout": "90s",
                    "maxIdleConns": 100,
                    "maxIdleConnsPerHost": 20,
                    "maxConnsPerHost": 200
                },
                "hosts": [
                    { "host": "10.0.1.1", "port": "8080" },
                    { "host": "10.0.1.2", "port": "8080" }
                ]
            }
        ]
    }
}
